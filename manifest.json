{
    "manifest_version": 3,
    "name": "Credentials changer",
    "description": "Capture cookies from any tab and apply them to another — ideal for switching between environments like production and localhost.",
    "version": "1.0.0",
    "icons": {
        "16": "logo/logo-16.png",
        "48": "logo/logo-48.png",
        "128": "logo/logo-128.png"
    },
    "options_page": "settings/settings.html",
    "action": {
        "default_title": "Credentials changer",
        "default_popup": "popup/popup.html"
    },
    "permissions": ["cookies", "activeTab", "storage"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "service-worker.js"
    }
}
